{
  "manifest_version": 3,
  "name": "StockVision — Salesforce",
  "version": "1.4",
  "description": "Copia Work Orders do Salesforce para o StockVision com um clique.",
  "homepage_url": "https://www.stockvision.pt",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.salesforce.com/*",
    "https://*.force.com/*",
    "https://*.lightning.force.com/*",
    "https://stockvision.pt/*",
    "https://*.stockvision.pt/*"
  ],
  "icons": {
    "16": "icons/logo-16.png",
    "48": "icons/logo-48.png",
    "128": "icons/logo-128.png",
    "32": "icons/logo-32.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "StockVision",
    "default_icon": {
      "16": "icons/logo-16.png",
      "48": "icons/logo-48.png",
      "128": "icons/logo-128.png",
      "32": "icons/logo-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.salesforce.com/*",
        "https://*.force.com/*",
        "https://*.lightning.force.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}